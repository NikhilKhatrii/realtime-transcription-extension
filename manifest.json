{
  "manifest_version": 3,
  "name": "Real-time Transcriber",
  "version": "1.1",
  "description": "Transcribes audio from your tab or microphone in real-time and displays captions.",
  "permissions": [
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "action": {
    "default_title": "Start Transcriber"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}